# Database
DATABASE_URL="file:./dev.db"

# AzuraCast (from inside Docker, use host.docker.internal or your host LAN IP, not localhost)
# Docker Desktop: http://host.docker.internal:8080
# Linux host:   http://192.168.x.x:8080  (find IP with: hostname -I | awk '{print $1}')
AZURACAST_API_URL="http://host.docker.internal:8080"
AZURACAST_API_TOKEN="your-api-token"

# Stream URL (client-facing, must be reachable from the browser, not from inside Docker)
NEXT_PUBLIC_STREAM_URL="http://localhost/listen/schrammel_stream/schrammel"

# App port
APP_PORT=3000

# Cleanup cron secret
CLEANUP_SECRET_TOKEN="change-me-to-a-secret-value"
