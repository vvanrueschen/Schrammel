// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Song {
  azuracastId String   @id
  artist    String
  title     String
  filePath    String?
  rating      Int      @default(0)
  plays       Int      @default(0)
  wishes    Wish[]
  votes     Vote[]
}

model Wish {
  id        Int      @id @default(autoincrement())
  songId    String?
  song      Song?    @relation(fields: [songId], references: [azuracastId])
  artist    String
  title     String
  weblink   String?
  upvotes   Int      @default(0)
  downvotes Int      @default(0)
  createdAt DateTime @default(now())
  votes     WishVote[]
}

model Vote {
  id        Int      @id @default(autoincrement())
  songId    String
  song      Song     @relation(fields: [songId], references: [azuracastId])
  deviceId  String
  value     Int
  createdAt DateTime @default(now())
}

model NowPlaying {
  id        Int      @id @default(autoincrement())
  artist    String
  title     String
  updatedAt DateTime @updatedAt
}

model WishVote {
  id        Int      @id @default(autoincrement())
  wishId    Int
  wish      Wish     @relation(fields: [wishId], references: [id])
  deviceId  String
  value     Int
  createdAt DateTime @default(now())
}
